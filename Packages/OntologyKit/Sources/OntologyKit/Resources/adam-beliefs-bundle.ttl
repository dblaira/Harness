@prefix understood: <https://understood.app/ontology#> .
@prefix recall:     <https://understood.app/ontology/project-recall#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:        <http://purl.org/dc/terms/> .
@prefix skos:       <http://www.w3.org/2004/02/skos/core#> .

#################################################################
#  Understood Suite — formal ontology document
#  Authority: Understood data · Structure: Re_Call engine · Surfaces: SAVY + iOS apps
#  Only confirmed + personal axioms govern prompts, graph projection, and RDF truth.
#################################################################

<https://understood.app/ontology> a owl:Ontology ;
  dct:title "Understood Suite Ontology"@en ;
  dct:description "Shared knowledge graph vocabulary for Understood, Re_Call, and SAVY."@en ;
  owl:versionInfo "suite-v1" ;
  owl:imports <https://understood.app/ontology/project-recall> .

#################################################################
#  Classes
#################################################################

understood:Axiom a owl:Class ;
  rdfs:label "Axiom"@en ;
  rdfs:comment "Human-confirmed causal rule: antecedent → consequent with evidence."@en .

understood:Concept a owl:Class ;
  rdfs:label "Concept"@en ;
  rdfs:comment "Named condition or outcome referenced by axioms."@en .

understood:LifeDomain a owl:Class ;
  rdfs:subClassOf skos:Concept ;
  rdfs:label "Life Domain"@en ;
  rdfs:comment "One of 13 closed analytic domains in the personal ontology."@en .

understood:Connection a owl:Class ;
  rdfs:label "Connection"@en ;
  rdfs:comment "Durable belief/principle captured as entry_type=connection."@en .

understood:Entry a owl:Class ;
  rdfs:label "Entry"@en ;
  rdfs:comment "Journal capture row that may support axioms."@en .

understood:RelationPolicy a owl:Class ;
  rdfs:label "Relation Policy"@en ;
  rdfs:comment "Semantic contract for an axiom relationship type."@en .

#################################################################
#  Object properties
#################################################################

understood:antecedent a owl:ObjectProperty ;
  rdfs:domain understood:Axiom ;
  rdfs:range understood:Concept .

understood:consequent a owl:ObjectProperty ;
  rdfs:domain understood:Axiom ;
  rdfs:range understood:Concept .

understood:supportedBy a owl:ObjectProperty ;
  rdfs:domain understood:Axiom ;
  rdfs:range understood:Entry ;
  rdfs:comment "Evidence entry that supports or informed the axiom."@en .

understood:inLifeDomain a owl:ObjectProperty ;
  rdfs:range understood:LifeDomain .

understood:relationshipPolicy a owl:ObjectProperty ;
  rdfs:domain understood:Axiom ;
  rdfs:range understood:RelationPolicy .

#################################################################
#  Datatype properties
#################################################################

understood:axiomId a owl:DatatypeProperty ; rdfs:domain understood:Axiom ; rdfs:range xsd:string .
understood:label a owl:DatatypeProperty ; rdfs:range xsd:string .
understood:relationshipType a owl:DatatypeProperty ; rdfs:range xsd:string .
understood:confidence a owl:DatatypeProperty ; rdfs:range xsd:decimal .
understood:evidenceCount a owl:DatatypeProperty ; rdfs:range xsd:integer .
understood:status a owl:DatatypeProperty ; rdfs:range xsd:string .
understood:scope a owl:DatatypeProperty ; rdfs:range xsd:string .
understood:provenanceSource a owl:DatatypeProperty ; rdfs:range xsd:string .
understood:connectionType a owl:DatatypeProperty ; rdfs:domain understood:Connection ; rdfs:range xsd:string .

