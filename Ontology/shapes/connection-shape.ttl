@prefix understood: <https://understood.app/ontology#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

understood:ConnectionShape
  a sh:NodeShape ;
  sh:targetClass understood:Connection ;
  sh:property [
    sh:path understood:label ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "missing label" ;
  ] ;
  sh:property [
    sh:path understood:connectionType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "missing or invalid connection type" ;
  ] ;
  sh:property [
    sh:path understood:inLifeDomain ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      <https://understood.app/ontology/domain/affect>
      <https://understood.app/ontology/domain/ambition>
      <https://understood.app/ontology/domain/belief>
      <https://understood.app/ontology/domain/entertainment>
      <https://understood.app/ontology/domain/exercise>
      <https://understood.app/ontology/domain/health>
      <https://understood.app/ontology/domain/insight>
      <https://understood.app/ontology/domain/learning>
      <https://understood.app/ontology/domain/nutrition>
      <https://understood.app/ontology/domain/purchase>
      <https://understood.app/ontology/domain/sleep>
      <https://understood.app/ontology/domain/social>
      <https://understood.app/ontology/domain/work>
    ) ;
    sh:message "unknown or missing life domain" ;
  ] ;
  sh:property [
    sh:path understood:strength ;
    sh:maxCount 1 ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:maxInclusive 1 ;
    sh:message "strength must be a decimal between 0 and 1" ;
  ] ;
  sh:property [
    sh:path understood:frequency ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:in ("usually" "sometimes") ;
    sh:message "frequency must be usually or sometimes" ;
  ] ;
  sh:property [
    sh:path understood:acceptedAt ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "acceptedAt must be a date-time" ;
  ] ;
  sh:property [
    sh:path understood:evidenceNote ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "evidence note must be text" ;
  ] .

understood:StepEvidenceRatingShape
  a sh:NodeShape ;
  sh:targetClass understood:StepEvidenceRating ;
  sh:property [
    sh:path understood:forStep ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      <http://nousresearch.com/adam-pattern#Step1>
      <http://nousresearch.com/adam-pattern#Step2>
      <http://nousresearch.com/adam-pattern#Step3>
      <http://nousresearch.com/adam-pattern#Step4>
      <http://nousresearch.com/adam-pattern#Step5>
      <http://nousresearch.com/adam-pattern#Step6>
      <http://nousresearch.com/adam-pattern#Step7>
      <http://nousresearch.com/adam-pattern#Step8>
    ) ;
    sh:message "unknown or missing pattern step" ;
  ] ;
  sh:property [
    sh:path understood:forBuild ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "missing build id" ;
  ] ;
  sh:property [
    sh:path understood:rating ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 1 ;
    sh:maxInclusive 10 ;
    sh:message "rating must be an integer between 1 and 10" ;
  ] ;
  sh:property [
    sh:path understood:evidenceNote ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:message "a rating requires an evidence note — if I can't say, I can't play" ;
  ] ;
  sh:property [
    sh:path understood:ratedAt ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "ratedAt must be a date-time" ;
  ] .

understood:UnpromptedSignalShape
  a sh:NodeShape ;
  sh:targetClass understood:UnpromptedSignal ;
  sh:property [
    sh:path understood:occurredAt ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "occurredAt must be a date-time" ;
  ] ;
  sh:property [
    sh:path understood:whoSaid ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "whoSaid must be a first name" ;
  ] ;
  sh:property [
    sh:path understood:whatTheySaid ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "whatTheySaid must be a short paraphrase" ;
  ] ;
  sh:property [
    sh:path understood:loggedBy ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "loggedBy must be text" ;
  ] .
